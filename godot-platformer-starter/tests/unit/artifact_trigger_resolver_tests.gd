extends RefCounted
const Resolver=preload("res://game/core/artifacts/artifact_trigger_resolver.gd")
func run()->Array[String]:
	var f:Array[String]=[];var r:=Resolver.new();r.configure(_bundle());var a=r.resolve({"type":"dash_passed_enemy","actionId":10,"targetKey":"one"});var b=r.resolve({"type":"dash_passed_enemy","actionId":10,"targetKey":"two"});var d=r.resolve({"type":"dash_passed_enemy","actionId":10,"targetKey":"one"});_assert(a.triggered and b.triggered and not d.triggered,"M5 two targets and dedup",f);var conflict=r.resolve({"type":"hard_landing","actionId":10,"fallSpeed":14,"airTimeSeconds":.4});_assert(conflict.reason=="main_artifact_already_selected","M5 single primary",f);_assert(r.resolve({"type":"double_jump_started","actionId":11}).artifact_id=="artifact_wind_ring","M5 wind ring positive",f);_assert(not r.resolve({"type":"hard_landing","actionId":12,"fallSpeed":8,"airTimeSeconds":.4}).triggered,"M5 starfall speed negative",f);_assert(not r.resolve({"type":"hard_landing","actionId":13,"fallSpeed":14,"airTimeSeconds":.1}).triggered,"M5 starfall air-time negative",f);_assert(r.resolve({"type":"hard_landing","actionId":14,"fallSpeed":14,"airTimeSeconds":.4}).artifact_id=="artifact_starfall_seal","M5 starfall positive",f);return f
func _bundle()->Dictionary:return {"artifacts":[{"id":"artifact_blade_talisman","slot":"horizontal","trigger":{"event":"dash_passed_enemy"},"effects":[{"type":"line_damage","damage":1}]},{"id":"artifact_wind_ring","slot":"upward","trigger":{"event":"double_jump_started"},"effects":[{"type":"area_damage","radius":2.8,"damage":1}]},{"id":"artifact_starfall_seal","slot":"downward","trigger":{"event":"hard_landing","conditions":{"minimumFallSpeed":12,"minimumAirTimeSeconds":.28}},"effects":[{"type":"area_damage","radius":2.6,"damage":1}]}]}
